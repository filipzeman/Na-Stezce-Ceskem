---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";

const maps = {
  main: "https://mapy.com/s/fevazepaka",
  ubytovani: "https://mapy.cz/...",
  obcerstveni: "https://mapy.cz/...",
  doprava: "https://mapy.cz/...",
};

const filters = [
  { key: "main", label: "Trasa", icon: "Route" },
  { key: "ubytovani", label: "Ubytování", icon: "Bed" },
  { key: "obcerstveni", label: "Občerstvení", icon: "Utensils" },
  { key: "doprava", label: "Doprava", icon: "BusFront" },
];
---

<BaseLayout title="Mapa | Na Stezce Českem">
  <!-- INTRO -->
  <section class="container intro">
    <h1>Mapa</h1>
    <div class="intro">
      <p class="subtitle">
        Zobrazte si náhled trasy a důležité body na trase. Pro zobrazení více informací o
        jednotlivých bodech si můžete kliknout na libovolný bod a otevře se vám plná verze mapy na <a
          href="https://mapy.cz/"
          target="_blank">Mapy.cz</a
        >.
        <!-- Přepínejte mezi vrstvami podle potřeby. -->
      </p>
    </div>
  </section>

  <!-- FILTERS -->
  <!-- <section class="container map-filters">
    {
      filters.map((f, i) => (
        <button class={`filter ${i === 0 ? "active" : ""}`} data-map={f.key}>
          <Icon name={f.icon} size={16} />
          <span>{f.label}</span>
        </button>
      ))
    }
  </section> -->

  <!-- MAP -->
  <section class="container map-section">
    <div class="map-wrapper">
      <div class="map-overlay" id="map-overlay">
        <div class="map-overlay-content">
          <Icon name="Map" size={20} />
          <span>Aktivovat mapu</span>
        </div>
      </div>
      <iframe id="map-frame" src={maps.main} loading="lazy" allowfullscreen></iframe>
    </div>

    <div class="map-actions">
      <a id="map-link" href={maps.main} target="_blank" class="btn btn-secondary">
        Otevřít v Mapy.cz
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const maps = {
    main: "https://mapy.cz/...",
    ubytovani: "https://mapy.cz/...",
    obcerstveni: "https://mapy.cz/...",
    doprava: "https://mapy.cz/...",
  };

  const frame = document.getElementById("map-frame") as HTMLIFrameElement | null;
  const link = document.getElementById("map-link") as HTMLAnchorElement | null;
  const buttons = document.querySelectorAll(".filter");

  buttons.forEach((btn) => {
    const button = btn as HTMLElement;
    button.addEventListener("click", () => {
      const key = button.dataset.map as keyof typeof maps;

      // active state
      buttons.forEach((b) => (b as HTMLElement).classList.remove("active"));
      button.classList.add("active");

      // update map
      if (frame) frame.src = maps[key];
      if (link) link.href = maps[key];
    });
  });

  const overlay = document.getElementById("map-overlay") as HTMLElement | null;
  const frame2 = document.getElementById("map-frame") as HTMLIFrameElement | null;

  if (overlay && frame2) {
    overlay.addEventListener("click", () => {
      frame2.style.pointerEvents = "auto";
      overlay.classList.add("hidden");
      setTimeout(() => {
        overlay.style.display = "none";
      }, 400);
    });
  }
</script>

<style>
  .map-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 1rem;
  }

  .filter {
    display: flex;
    align-items: center;
    gap: 6px;

    padding: 8px 12px;
    border-radius: 999px;

    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);

    font-size: 0.9rem;
  }

  .filter.active {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .map-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .map-wrapper {
    width: 100%;
    height: 60vh;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    position: relative;
  }

  .map-wrapper iframe {
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: none;
  }

  .map-overlay {
    position: absolute;
    inset: 0;

    display: flex;
    align-items: center;
    justify-content: center;

    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(2px);

    z-index: 10;
    cursor: pointer;

    transition: opacity 0.4s ease;
  }

  .map-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .map-overlay-content {
    display: flex;
    align-items: center;
    gap: 8px;

    padding: 10px 14px;
    border-radius: 999px;

    background: white;
    border: 1px solid var(--color-border);

    font-size: 0.85rem;
    color: var(--color-text);

    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
  }

  .map-actions {
    display: flex;
    justify-content: flex-end;
  }
</style>

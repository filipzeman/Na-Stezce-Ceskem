---
import BaseLayout from "../layouts/BaseLayout.astro";

import UploadTest from "../admin/test/UploadTest";

import "../admin/styles/admin.css";
---

<BaseLayout title="Test Upload">
  <section class="container">
    <UploadTest client:load />
  </section>
</BaseLayout>

<style is:global>
  .upload-test {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 40px 0;
  }

  .upload-preview {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .upload-preview img {
    width: 100%;
    max-width: 420px;
    border-radius: 18px;
    border: 1px solid var(--color-border);
  }

  .upload-meta {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .upload-meta code {
    display: block;
    padding: 12px;
    border-radius: 12px;
    background: var(--color-surface-secondary);
    overflow-x: auto;
    font-size: 0.85rem;
  }

  .image-field {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .image-preview {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .image-preview img {
    width: 100%;
    max-width: 320px;
    border-radius: 18px;
    border: 1px solid var(--color-border);
  }

  .image-actions {
    display: flex;
    gap: 12px;
  }

  .image-empty {
    display: flex;
  }

  .gallery-test {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 12px;
  }

  .gallery-test img {
    width: 100%;
    height: 100px;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 14px;
    border: 1px solid var(--color-border);
  }
</style>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabase } from "../lib/supabase.ts";
import PointCard from "../components/PointCard.astro";

import { categoryMap, typeMap } from "../utils/dataMapping.ts";
import { mapKey } from "../utils/mapKey.ts";
import { groupPointsByLocation } from "../utils/groupPoints";
import type { Point } from "../types/point";
import Icon from "../components/Icon.astro";

const supabase = getSupabase();
let { data } = await supabase.from("points").select("*").order("km", { ascending: true });

let points = data as Point[];

if (!points) { 
  points = [];
  console.error("Nenalezena žádná data o bodech.");
} else {
  console.log(`Načteno ${points.length} bodů z databáze.`);
}

const sortedPoints = points
  .map((p) => ({
    ...p,
    categoryKey: mapKey(categoryMap, p.category),
    typeKey: mapKey(typeMap, p.type),
  }))
  .sort((a, b) => a.km - b.km);

const groupedPoints = groupPointsByLocation(sortedPoints);
groupedPoints.sort((a, b) => a.km - b.km);

const filter = Astro.url.searchParams.get("filtr");
const showGroupedPoints = !filter || filter === "vse";

const filteredPoints = sortedPoints.filter((point) => {
  if (!filter || filter === "vse") return true;
  return point.categoryKey === filter;
});

const pointsToRender = showGroupedPoints ? groupedPoints : filteredPoints;

const filters = [
  { key: "vse", label: "Vše", icon: "LayoutGrid" },
  { key: "ubytovani", label: "Ubytování", icon: "Bed" },
  { key: "obcerstveni", label: "Občerstvení", icon: "Utensils" },
  { key: "navigace", label: "Navigace", icon: "Signpost" },
  { key: "doprava", label: "Doprava", icon: "BusFront" },
  { key: "turisticke_cile", label: "Cíle", icon: "MapPin" },
  { key: "ostatni", label: "Ostatní", icon: "Info" },
];
---

<BaseLayout title="Itinerář | Orlické hory">
  <section class="container intro-compact">
    <div class="intro-text">
      <h1>Itinerář</h1>
      <p>Přehled bodů podél trasy.</p>
    </div>

    <div class="geo-row">
      <button id="location-btn" class="btn btn-primary"> Moje poloha</button>

      <span id="locate-status" class="geo-status"></span>
    </div>
  </section>

  <!-- FILTER BAR (ONLY STICKY ELEMENT) -->
  <section class="filter-bar">
    <div class="filter-bar-inner container">
      {
        filters.map((f) => (
          <a
            href={`/itinerar?filtr=${f.key}`}
            class={`filter-icon ${(filter ?? "vse") === f.key ? "active" : ""}`}
            aria-label={f.label}
          >
            <Icon name={f.icon} size={18} />
          </a>
        ))
      }
   </div>
    
  </section>

  <!-- CONTENT -->
  <section class="container points">
    {pointsToRender.length === 0 && (
      <p class="text-center text-muted">Bohužel nejsou k dispozici žádná data (technická chyba), prosím dejte nám o tom vědět pomocí kontaktního formuláře, moc děkujeme.</p>
    )}
    {
      pointsToRender.map((point, index) => (
        <PointCard filter={filter} point={point} last={index === pointsToRender.length - 1} />
      ))
    }
  </section>
</BaseLayout>
<script type="module">
  window.addEventListener("DOMContentLoaded", () => {
    const locationBtn = document.getElementById("location-btn");
    console.log("Location button:", locationBtn);
    const status = document.getElementById("locate-status");

    let locationActive = false;
    let currentElement = null;

    const filterBar = document.querySelector(".filter-bar");

  function handleSticky() {
    const rect = filterBar.getBoundingClientRect();

    if (rect.top <= 65) {
      filterBar.classList.add("is-sticky");
    } else {
      filterBar.classList.remove("is-sticky");
    }
  }

  window.addEventListener("scroll", handleSticky);

    // --- helpers ---
    function toRad(v) {
      return (v * Math.PI) / 180;
    }

    function distance(a, b) {
      const R = 6371;  

      const dLat = toRad(b.lat - a.lat);
      const dLng = toRad(b.lng - a.lng);

      const lat1 = toRad(a.lat);
      const lat2 = toRad(b.lat);

      const aVal =
        Math.sin(dLat / 2) ** 2 + Math.sin(dLng / 2) ** 2 * Math.cos(lat1) * Math.cos(lat2);

      const c = 2 * Math.atan2(Math.sqrt(aVal), Math.sqrt(1 - aVal));

      return R * c;
    }

    function highlightNearest(user) {
      const items = Array.from(document.querySelectorAll(".item"));

      let closest = null;
      let minDist = Infinity;

      items.forEach((el) => {
        const lat = parseFloat(el.dataset.lat);
        const lng = parseFloat(el.dataset.lng);

        if (!lat || !lng) return;

        const d = distance(user, { lat, lng });

        if (d < minDist) {
          minDist = d;
          closest = el;
        }
      });

      if (!closest) return null;

      document.querySelectorAll(".item.active").forEach((i) => i.classList.remove("active"));

      closest.classList.add("active");

      return closest;
    }

    function getStickyOffset() {
      const stickyNav = document.querySelector(".sticky-nav");

      let height = 0;

      if (stickyNav) height += stickyNav.offsetHeight;

      return height;
    }

    function scrollToElement(el) {
      const offset = getStickyOffset();

      const y = el.getBoundingClientRect().top + window.pageYOffset - offset - 150;

      window.scrollTo({
        top: y,
        behavior: "smooth",
      });
    }

    // --- restore previous session ---
    const stored = sessionStorage.getItem("user-location");

    if (stored) {
      const user = JSON.parse(stored);
      const el = highlightNearest(user);

      if (el) {
        currentElement = el;
        locationActive = true;
        locationBtn.textContent = "Poloha aktivní";
      }
    }

    // --- main button logic ---
    locationBtn?.addEventListener("click", () => {
      // FIRST CLICK → get location
      if (!locationActive) {
        if (!navigator.geolocation) {
          status.textContent = "Geolokace není podporována";
          return;
        }

        status.textContent = "Získávám polohu…";

        navigator.geolocation.getCurrentPosition(
          (pos) => {
            const user = {
              lat: pos.coords.latitude,
              lng: pos.coords.longitude,
            };

            sessionStorage.setItem("user-location", JSON.stringify(user));

            const el = highlightNearest(user);

            if (el) {
              currentElement = el;
              scrollToElement(el);
            }

            locationActive = true;
            locationBtn.textContent = "📍 Poloha aktivní";
            status.textContent = "";
          },
          () => {
            status.textContent = "Poloha zamítnuta";
          }
        );
      }
      // NEXT CLICKS → just scroll
      else {
        if (currentElement) {
          scrollToElement(currentElement);
        }
      }
    });
  });
</script>

<style>

  .intro-compact {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.intro-text h1 {
  margin-bottom: 1rem;
  font-size: 1.2rem;
}

.intro-text p {
  font-size: 0.85rem;
  color: var(--color-text);
}

.geo-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.geo-status {
  font-size: 0.8rem;
  color: var(--color-text-muted);
}

.filter-bar {
  position: sticky;
  top: var(--mobile-header-height);
  z-index: 30;

  display: flex;
  gap: 10px;
 

  overflow-x: auto;

  background: var(--color-bg); /* default */
  transition: background 0.2s ease, border-color 0.2s ease;

  @media (min-width: 768px) {
    top: var(--desktop-header-height);
  }
}

/* sticky state */
.filter-bar.is-sticky {
  background: var(--color-surface);
  box-shadow: 0 2px 6px rgba(0,0,0,0.06);
}

.filter-bar::-webkit-scrollbar {
    display: none;
}

.filter-bar-inner {
  display: flex;
  max-width: var(--max-width);
  margin: 0 auto;

  gap:0.8rem;
  width:100%;
  padding: 12px 16px;
}

  /* ICON BUTTON */
  .filter-icon {
    flex: 0 0 auto;

    width: 36px;
    height: 36px;

    display: flex;
    align-items: center;
    justify-content: center;

    border-radius: 10px;

    background: var(--color-surface);
    border: 1px solid var(--color-border);

    color: var(--color-text);
  }

  /* ACTIVE */
  .filter-icon.active {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);

    svg {
      color: var(--color-surface);
    }
  }

  /* TOUCH */
  .filter-icon:active {
    transform: scale(0.95);
  }

  /* SNAP (nice UX) */
  .filter-bar {
    scroll-snap-type: x mandatory;
  }

  .filter-icon {
    scroll-snap-align: start;
  }

  /* POINTS */
  .points {
    display: flex;
    flex-direction: column;
    padding-left: 20px;
  }

  :global(.item.active) {
    background: rgba(47, 133, 90, 0.05);
    border-radius: 10px;
  }

  :global(.item.active::before) {
    width: 14px;

    height: 14px;

    background: var(--color-accent);

    border: 3px solid white;

    box-shadow: 0 0 0 3px var(--color-accent);

    transform: scale(1.1);
    top: 0.6rem;
    left: -5px;

    transition: all 0.2s ease;
    animation: pulse 1.5s infinite;
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(47, 133, 90, 0.4);
    }

    70% {
      box-shadow: 0 0 0 6px rgba(47, 133, 90, 0);
    }

    100% {
      box-shadow: 0 0 0 0 rgba(47, 133, 90, 0);
    }
  }

  /* BUTTON STATE */
  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;

  /* desktop */
  @media (min-width: 768px) {
    .filter-bar {
      justify-content: center;
      mask-image: none;
    }
  }
</style>

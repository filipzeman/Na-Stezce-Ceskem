---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabase } from "../lib/supabase.ts";
import PointCard from "../components/PointCard.astro";

import { categoryMap, typeMap } from "../utils/dataMapping.ts";
import { mapKey } from "../utils/mapKey.ts";
import { groupPointsByLocation } from "../utils/groupPoints";
import type { Point } from "../types/point";

const supabase = getSupabase();
let { data } = await supabase.from("points").select("*").order("km", { ascending: true });

let points = data as Point[];

if (!points) return null;

const sortedPoints = points
  .map((p) => ({
    ...p,
    categoryKey: mapKey(categoryMap, p.category),
    typeKey: mapKey(typeMap, p.type),
  }))
  .sort((a, b) => a.km - b.km);

const groupedPoints = groupPointsByLocation(sortedPoints);
groupedPoints.sort((a, b) => a.km - b.km);

const filter = Astro.url.searchParams.get("filtr");
const showGroupedPoints = !filter || filter === "vse";

const filteredPoints = sortedPoints.filter((point) => {
  if (!filter || filter === "vse") return true;
  return point.categoryKey === filter;
});

const pointsToRender = showGroupedPoints ? groupedPoints : filteredPoints;

const filters = [
  { key: "vse", label: "Vše" },
  { key: "ubytovani", label: "Ubytování" },
  { key: "obcerstveni", label: "Občerstvení" },
  { key: "navigace", label: "Navigace" },
  { key: "doprava", label: "Doprava" },
  { key: "turisticke_cile", label: "Turistické cíle" },
  { key: "ostatni", label: "Ostatní" },
];
---

<BaseLayout title="Itinerář | Orlické hory">
  <section class="container">
    <h1>Itinerář</h1>
    <p class="subtitle">Přehled bodů podél trasy.</p>
  </section>

  <!-- STICKY NAV -->
  <section class="container sticky-nav">
    <!-- FILTERS -->
    <div class="filters">
      {
        filters.map((f) => (
          <a
            href={`/itinerar?filtr=${f.key}`}
            class={`filter ${(filter ?? "vse") === f.key ? "active" : ""}`}
          >
            {f.label}
          </a>
        ))
      }
    </div>

    <!-- LOCATION BAR -->
    <div class="location-bar">
      <button id="locate-btn" class="btn btn-primary">Moje poloha</button>

      <button id="scroll-btn" class="btn btn-secondary hidden" disabled>
        Přejít na moji polohu
      </button>

      <span id="locate-status" class="locate-status"></span>
    </div>

    <!-- INFO BAR (future dynamic) -->
    <div class="info-bar">
      <div class="info-item">Občerstvení —</div>
      <div class="info-item">Ubytování —</div>
      <div class="info-item">Doprava —</div>
    </div>
  </section>

  <!-- POINTS -->
  <section class="container points">
    {
      pointsToRender.map((point, index) => (
        <PointCard filter={filter} point={point} last={index === pointsToRender.length - 1} />
      ))
    }
  </section>
</BaseLayout>

<script type="module">
  window.addEventListener("DOMContentLoaded", () => {
    const locateBtn = document.getElementById("locate-btn");
    const scrollBtn = document.getElementById("scroll-btn");
    const status = document.getElementById("locate-status");

    let currentElement = null;

    function enableScrollButton() {
      scrollBtn.classList.remove("hidden");
      scrollBtn.disabled = false;
    }

    function distance(a, b) {
      const R = 6371;
      const dLat = toRad(b.lat - a.lat);
      const dLng = toRad(b.lng - a.lng);

      const lat1 = toRad(a.lat);
      const lat2 = toRad(b.lat);

      const aVal =
        Math.sin(dLat / 2) ** 2 + Math.sin(dLng / 2) ** 2 * Math.cos(lat1) * Math.cos(lat2);

      const c = 2 * Math.atan2(Math.sqrt(aVal), Math.sqrt(1 - aVal));
      return R * c;
    }

    function toRad(v) {
      return (v * Math.PI) / 180;
    }

    function highlightNearest(user) {
      const items = Array.from(document.querySelectorAll(".item"));

      let closest = null;
      let minDist = Infinity;

      items.forEach((el) => {
        const lat = parseFloat(el.dataset.lat);
        const lng = parseFloat(el.dataset.lng);

        if (!lat || !lng) return;

        const d = distance(user, { lat, lng });

        if (d < minDist) {
          minDist = d;
          closest = el;
        }
      });

      if (!closest) return null;

      document.querySelectorAll(".item.active").forEach((i) => i.classList.remove("active"));

      closest.classList.add("active");

      return closest;
    }

    // restore session
    const stored = sessionStorage.getItem("user-location");

    if (stored) {
      const user = JSON.parse(stored);
      const el = highlightNearest(user);

      if (el) {
        currentElement = el;
        enableScrollButton();
      }
    }

    locateBtn?.addEventListener("click", () => {
      if (!navigator.geolocation) {
        status.textContent = "Geolokace není podporována";
        return;
      }

      status.textContent = "Získávám polohu…";

      navigator.geolocation.getCurrentPosition(
        (pos) => {
          const user = {
            lat: pos.coords.latitude,
            lng: pos.coords.longitude,
          };

          sessionStorage.setItem("user-location", JSON.stringify(user));

          const el = highlightNearest(user);

          if (el) {
            currentElement = el;

            const isFirstLocate = !sessionStorage.getItem("location-initialized");

            if (isFirstLocate) {
              el.scrollIntoView({
                behavior: "smooth",
                block: "center",
              });

              sessionStorage.setItem("location-initialized", "true");
            }

            enableScrollButton();
          }

          status.textContent = "Poloha aktivní";
        },
        (err) => {
          console.log(err);
          status.textContent = "Poloha zamítnuta";
        }
      );
    });

    scrollBtn?.addEventListener("click", () => {
      if (!currentElement) return;

      currentElement.scrollIntoView({
        behavior: "smooth",
        block: "center",
      });
    });
  });
</script>

<style>
  :root {
    --color-accent: #2f855a;
    --header-height: 60px;
  }

  /* STICKY NAV */
  .sticky-nav {
    position: sticky;
    top: var(--header-height);
    z-index: 30;

    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  /* FILTERS */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 8px 0;
  }

  .filter {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .filter.active {
    background: var(--color-primary);
    color: white;
    border: transparent;
  }

  /* LOCATION BAR */
  .location-bar {
    display: flex;
    gap: 10px;
    align-items: center;
    padding: 8px 0;
    flex-wrap: wrap;
  }

  .locate-status {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .hidden {
    display: none;
  }

  /* INFO BAR */
  .info-bar {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding: 8px 0;
    /* border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border); */
  }

  .info-item {
    padding: 6px 10px;
    border-radius: 999px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    font-size: 0.85rem;
    white-space: nowrap;
  }

  /* POINTS */
  .points {
    display: flex;
    flex-direction: column;
    padding-left: 20px;
  }

  :global(.item.active) {
    background: rgba(47, 133, 90, 0.05);
    border-radius: 10px;
  }

  :global(.item.active::before) {
    width: 14px;

    height: 14px;

    background: var(--color-accent);

    border: 3px solid white;

    box-shadow: 0 0 0 3px var(--color-accent);

    transform: scale(1.1);
    top: 0.6rem;
    left: -5px;

    transition: all 0.2s ease;
    animation: pulse 1.5s infinite;
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(47, 133, 90, 0.4);
    }

    70% {
      box-shadow: 0 0 0 6px rgba(47, 133, 90, 0);
    }

    100% {
      box-shadow: 0 0 0 0 rgba(47, 133, 90, 0);
    }
  }

  /* BUTTON STATE */
  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

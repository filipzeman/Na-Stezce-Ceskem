---
import BaseLayout from "../layouts/BaseLayout.astro";
import FaqAccordion from "../components/FaqAccordion.astro";

import { getSupabase } from "../lib/supabase.ts";
import type { FaqItem } from "../types/faq";

const supabase = getSupabase();
let { data } = await supabase.from("faq").select("*").order("created_at", { ascending: true });

let faqs = data as FaqItem[];

if (!faqs) {
  faqs = [];
  console.error("Nenalezena žádná data o FAQ.");
} else {
  console.log(`Načteno ${faqs.length} FAQ z databáze.`);
}

const validFaqs = faqs.filter((faq) => faq.question && faq.answer && faq.is_published === true);
const faqCategories = Array.from(new Set(validFaqs.map((faq) => faq.category).filter(Boolean)));


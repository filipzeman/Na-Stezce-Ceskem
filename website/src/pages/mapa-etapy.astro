---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";

const maps = {
  main: "https://mapy.com/s/fevazepaka",
  ubytovani: "https://mapy.cz/...",
  obcerstveni: "https://mapy.cz/...",
  doprava: "https://mapy.cz/...",
};

const filters = [
  { key: "main", label: "Trasa", icon: "Route" },
  { key: "ubytovani", label: "Ubytování", icon: "Bed" },
  { key: "obcerstveni", label: "Občerstvení", icon: "Utensils" },
  { key: "doprava", label: "Doprava", icon: "BusFront" },
];
---

<BaseLayout title="Mapa | Na Stezce Českem">
  <!-- INTRO -->
  <section class="container intro">
    <h1>Mapa</h1>
    <p class="subtitle">
      Zobrazte trasu a důležité body na mapě Mapy.cz.
      <!-- Přepínejte mezi vrstvami podle potřeby. -->
    </p>
  </section>

  <!-- FILTERS -->
  <!-- <section class="container map-filters">
    {
      filters.map((f, i) => (
        <button class={`filter ${i === 0 ? "active" : ""}`} data-map={f.key}>
          <Icon name={f.icon} size={16} />
          <span>{f.label}</span>
        </button>
      ))
    }
  </section> -->

  <!-- MAP -->
  <section class="container map-section">
    <div class="map-wrapper">
      <iframe id="map-frame" src={maps.main} loading="lazy" allowfullscreen></iframe>
    </div>

    <div class="map-actions">
      <a id="map-link" href={maps.main} target="_blank" class="btn btn-secondary">
        Otevřít v Mapy.cz
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const maps = {
    main: "https://mapy.cz/...",
    ubytovani: "https://mapy.cz/...",
    obcerstveni: "https://mapy.cz/...",
    doprava: "https://mapy.cz/...",
  };

  const frame = document.getElementById("map-frame");
  const link = document.getElementById("map-link");
  const buttons = document.querySelectorAll(".filter");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const key = btn.dataset.map;

      // active state
      buttons.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");

      // update map
      frame.src = maps[key];
      link.href = maps[key];
    });
  });
</script>

<style>
  .map-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 1rem;
  }

  .filter {
    display: flex;
    align-items: center;
    gap: 6px;

    padding: 8px 12px;
    border-radius: 999px;

    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);

    font-size: 0.9rem;
  }

  .filter.active {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .map-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .map-wrapper {
    width: 100%;
    height: 60vh;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .map-wrapper iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .map-actions {
    display: flex;
    justify-content: flex-end;
  }
</style>

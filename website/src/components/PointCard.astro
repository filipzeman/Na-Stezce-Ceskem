---
import Icon from "./Icon.astro";
import { getPointIcons, getPointTypeIcons } from "../utils/iconMapping";
import DetailedInfo from "./DetailedInfo.astro";
import { slugify } from "../utils/slugify.ts";
import type { Point } from "../types/point";
import type { LocationGroup } from "../types/locationGroup";

const { filter, point, last } = Astro.props as {
  filter?: string;
  point: Point | LocationGroup;
  last?: boolean;
};

const isGroup = Array.isArray((point as LocationGroup).points);
const hasLocation = point.location_id;
const isFilteredView = !!filter && filter !== "vse";
const isDefaultView = !isFilteredView;
const pointAsPoint = point as Point;
const pointAsGroup = point as LocationGroup;

const icons = getPointIcons(pointAsPoint);

const groupIcons = isGroup
  ? Array.from(new Set(pointAsGroup.points.flatMap((p) => getPointTypeIcons(p))))
  : [];

if (!icons.length && !isGroup) {
  return null;
}

const pointTypeIcon: string = !isGroup ? icons.shift() || "" : "";

const displayName = isGroup
  ? pointAsGroup.location_name || pointAsGroup.points[0]?.point_name
  : pointAsPoint.point_name;

const slug = isGroup || hasLocation ? pointAsGroup.location_id : slugify(pointAsPoint.point_name);

const isNavigation = filter === "navigace" && !isGroup;

// map Czech colors → UI colors
function getColor(color: string) {
  switch (color?.toLowerCase()) {
    case "červená":
      return "#c53030";
    case "modrá":
      return "#0469c8";
    case "zelená":
      return "#1d9405";
    case "žlutá":
      return "#e8c517";
    // case "cyklo":
    //   return "#f8c8dc";
    default:
      return "#ddd";
  }
}

// line color (only for navigation)
const lineColor =
  isNavigation && pointAsPoint.navigation_color
    ? getColor(pointAsPoint.navigation_color)
    : "#747474";
---

<div
  class={`item ${isNavigation ? "navigation" : ""} ${last ? "last" : ""}`}
  style={`--line-color: ${lineColor}`}
  data-lat={isGroup ? pointAsGroup.points[0]?.latitude : pointAsPoint.latitude}
  data-lng={isGroup ? pointAsGroup.points[0]?.longitude : pointAsPoint.longitude}
>
  <!-- KM -->
  <div class=`km ${isNavigation ? "no-accent" : ""}`>
    <span>{isGroup ? pointAsGroup.km : pointAsPoint.km}</span>
  </div>

  <!-- CONTENT -->
  <div class={!filter || filter === "vse" ? "content default" : "content"}>
    <a href={`/bod/${slug}`} class="name">
      {displayName}
    </a>
    {
      isGroup ? (
        <div class="icons-wrapper">
          {groupIcons.map((icon) => (
            <Icon name={icon} notInteractive />
          ))}
        </div>
      ) : (
        <span class="card-header">
          <Icon name={getPointTypeIcons(point)} size={18} notInteractive />
        </span>
      )
    }

    {isFilteredView && <DetailedInfo point={pointAsPoint} />}
  </div>
</div>

<style>
  .item {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 1rem;
    position: relative;
    align-content: center;
  }

  /* DOT (anchor point) */
  .item::before {
    position: absolute;
    content: "";
    left: -2px;
    top: 0.9rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: white;
    border: 2px solid var(--color-text-muted);
    z-index: 2;
  }

  /* LINE SEGMENT */
  .item::after {
    content: "";
    position: absolute;
    left: 4px;
    top: 1.1rem;
    bottom: -1rem;
    width: 2px;
    background: var(--line-color, #747474);
    z-index: 1;
  }

  .item.navigation::after {
    width: 3px;
    left: 3px;
  }

  /* last item → no segment */
  .item.last::after {
    display: none;
  }

  /* KM */
  .km {
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text-muted);
    text-align: right;
    padding-left: 1rem;
    padding-top: 0.4rem;

    &.no-accent {
      color: var(--color-text);
    }
  }

  /* CONTENT */
  .content {
    display: flex;
    flex-direction: column;
    padding: 0.4rem 0;
    align-items: flex-start;
  }

  /* NAME */
  .name {
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  /* ICONS */
  .icons-wrapper {
    display: flex;
    gap: 0.5rem;
  }

  /* optional */
  .small {
    font-size: 0.75rem;
    opacity: 0.6;
  }
</style>

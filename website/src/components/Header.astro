---
import Icon from "./Icon.astro";
import { FIRST_LEVEL_NAVIGATION } from "../constants/constants";
import { createNavItems } from "../utils/slugify";

const currentPath = Astro.url.pathname;
const firstLevelNavigationItems = createNavItems(FIRST_LEVEL_NAVIGATION);
---

<header class="header">
  <div class="inner">
    <div class="header-actions">
      <div><a href="/" class="logo">Na Stezce Českem</a>
      <div class="header-status">
        <div class="connection-status" id="connection-status">
          <svg
            class="status-icon online"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M5 12.55a11 11 0 0 1 14.08 0"></path>
            <path d="M1.42 9a16 16 0 0 1 21.16 0"></path>
            <path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path>
            <line x1="12" y1="20" x2="12.01" y2="20"></line>
          </svg>
          <span class="status-text">Online</span>
        </div>
      </div></div>
      

      <button class="menu-toggle" aria-expanded="false" aria-controls="nav">
        <Icon name="SquareMenu" noBackground size={26} />
        <span class="sr-only">Menu</span>
      </button>
    </div>

    <nav id="nav" class="nav">
      {
        firstLevelNavigationItems.map((item) => (
          <a href={`/${item.slug}`} class={currentPath === `/${item.slug}` ? "active" : ""}>
            {item.name}
          </a>
        ))
      }
    </nav>
  </div>
  <script>
    const toggle = document.querySelector(".menu-toggle");
    const nav = document.querySelector(".nav");

    toggle?.addEventListener("click", () => {
      const isOpen = nav?.classList.toggle("open");
      toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
    });

    // Connection status indicator
    function updateConnectionStatus() {
      const statusEl = document.getElementById("connection-status");
      const iconEl = statusEl?.querySelector(".status-icon");
      const textEl = statusEl?.querySelector(".status-text");

      if (!statusEl || !iconEl || !textEl) return;

      const isOnline = navigator.onLine;

      if (isOnline) {
        statusEl.classList.remove("offline");
        textEl.textContent = "Online";
        iconEl.innerHTML = `
          <path d="M5 12.55a11 11 0 0 1 14.08 0"/>
          <path d="M1.42 9a16 16 0 0 1 21.16 0"/>
          <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/>
          <line x1="12" y1="20" x2="12.01" y2="20"/>
        `;
      } else {
        statusEl.classList.add("offline");
        textEl.textContent = "Offline";
        iconEl.innerHTML = `
          <line x1="1" y1="1" x2="23" y2="23"/>
          <path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/>
          <path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/>
          <path d="M10.71 5.05A16 16 0 0 1 22.58 9"/>
          <path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/>
          <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/>
          <line x1="12" y1="20" x2="12.01" y2="20"/>
        `;
      }
    }

    // Update on load and when connection changes
    document.addEventListener("DOMContentLoaded", updateConnectionStatus);
    window.addEventListener("online", updateConnectionStatus);
    window.addEventListener("offline", updateConnectionStatus);
  </script>

  <style>
    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: white;
      border-bottom: 1px solid #eee;
      /* justify-content: center;
      display: flex; */
    }

    .inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: space-between;
      padding: 0.7rem 1.5rem;
      max-width: var(--max-width);

      @media (min-width: 768px) {
        padding: 20px 1rem;
        flex-direction: row;
        margin: 0 auto;
        height: 66px;
      }
    }

    .header-actions {
      display: flex;
      width: 100%;
      justify-content: space-between;
      align-items: center;

      @media (min-width: 768px) {
        width: auto;
      }
    }

    .logo {
      font-weight: 600;
      text-decoration: none;
      color: inherit;
      white-space: nowrap;
      margin-left: auto;
      margin-right: 1rem;
    }

    .menu-toggle {
      background: none;
      border: none;
      display: flex;
      font-size: 1.2rem;
      cursor: pointer;
      width: 42px;
      height: 42px;

      svg {
        stroke: black;
      }
    }

    .header-status {  
      display: inline-flex;
      }

      .connection-status {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 12px;
      color: var(--color-text-muted);
      padding: 4px 8px;
      border-radius: 12px;
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      transition: all 0.2s ease;
    }

    .connection-status.offline {
      background: #fef2f2;
      border-color: #fecaca;
      color: #dc2626;
    }

    .connection-status.offline .status-icon {
      color: #dc2626;
    }

    .status-icon {
      width: 14px;
      height: 14px;
      color: var(--color-text-muted);
      transition: color 0.2s ease;
    }

    .status-text {
      font-weight: 500;
    }
    }

  

    /* Mobile nav */
    .nav {
      display: none;
      flex-direction: column;
      background: white;
    }

    .nav a {
      padding: 0.6rem 0;
      text-decoration: none;
      color: var(--color-text);
      border-bottom: 1px solid #f0f0f0;

      &:last-of-type {
        border-bottom: none;
      }
    }

    .nav a.active {
      color: var(--color-primary);
      font-weight: 600;
    }

    .nav.open {
      display: flex;
      width: 100%;

      @media (min-width: 768px) {
        justify-content: flex-end;
      }
    }

    /* Desktop */
    @media (min-width: 768px) {
      .menu-toggle {
        display: none;
      }

      .nav {
        display: flex !important;
        flex-direction: row;
        gap: 1.5rem;
        padding: 0;
      }

      .nav a {
        border: none;
        padding: 0;
      }
    }

    /* Accessibility helper */
    .sr-only {
      position: absolute;
      left: -9999px;
    }
  </style>
</header>

---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import InstallBanner from "../components/InstallBanner.astro";
import InstallModal from "../components/InstallModal.astro";
import "../styles/globals.css";
import "../styles/tokens.css";
import "../styles/utilities.css";

import { getSettingsObject } from "../lib/settings.ts";

const settings = await getSettingsObject();

const {
  title = settings.title || "Na Stezce Českem | Orlické hory",
  description = settings.description ||
    "Digitální průvodce etapou Orlické hory - Na Stezce Českem.",
  image = settings.image || "images/hero.jpg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://orlicke-hory.vercel.app");
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Orlické hory" />

    <!-- Twitter Card -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- Additional Meta Tags -->
    <meta name="robots" content="noindex, nofollow" />
    <meta name="author" content="Orlické hory" />
    <meta name="theme-color" content="#0f172a" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/src/styles/tokens.css" />
    <link rel="stylesheet" href="/src/styles/globals.css" />
    <link rel="manifest" href="/manifest.webmanifest" />
  </head>

  <body>
    <Header settings={settings} />
    <InstallBanner />
    <InstallModal />
    <main class="page">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  if ("serviceWorker" in navigator) {
    window.addEventListener("load", () => {
      navigator.serviceWorker.register("/sw.js");
    });
  }
</script>
<script>
  function showOfflineToast(message: string, type = "info", duration = 4000) {
    const toast = document.createElement("div");
    toast.className = `offline-toast ${type}`;

    const iconName =
      type === "offline"
        ? "wifi-off"
        : type === "online"
          ? "wifi"
          : type === "ready"
            ? "check-circle"
            : "info";

    toast.innerHTML = `
      <svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        ${getIconPath(iconName)}
      </svg>
      <span class="toast-message">${message}</span>
      <button class="toast-close" onclick="this.parentElement.remove()" aria-label="Zavřít">×</button>
    `;

    document.body.appendChild(toast);

    // Auto-remove after duration
    setTimeout(() => {
      if (toast.parentElement) {
        toast.remove();
      }
    }, duration);

    // Add show class for animation
    setTimeout(() => toast.classList.add("show"), 10);
  }

  function getIconPath(iconName: "wifi-off" | "wifi" | "check-circle" | "info") {
    const icons = {
      "wifi-off":
        '<line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.58 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>',
      wifi: '<path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>',
      "check-circle":
        '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22,4 12,14.01 9,11.01"/>',
      info: '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
    };
    return icons[iconName] || icons["info"];
  }

  window.addEventListener("load", () => {
    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.ready.then(() => {
        showOfflineToast("Aplikace je připravena pro offline použití", "ready", 5000);
      });
    }
  });

  window.addEventListener("offline", () => {
    showOfflineToast("Jste offline - aplikace funguje bez internetu", "offline", 6000);
  });

  window.addEventListener("online", () => {
    showOfflineToast("Zpět online", "online", 3000);
  });
</script>
